#include <stdio.h>

int function(int num2){

    if (num2 == 0 || num2 == 1){
        return 1;

    }else{
        return function(num2 - 1) + function(num2 - 2 );
    }
};


int main(){

    int num;
    printf("Enter number to do fibonnaci sequence on: ");
    scanf("%d", &num);

    // call function here
    int result = function(num); // store the result of the function call

    printf("The %dth Fibonacci number is: %d\n", num, result);
    return 0;

}
